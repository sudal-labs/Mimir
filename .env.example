# ────────────────────────────────────────────────
# .env.example — 환경 변수 템플릿
# 실제 값은 .env 파일에 복사 후 채워 넣으세요 (cp .env.example .env)
# .env 파일은 .gitignore에 포함되어 있어 커밋되지 않습니다.
# ────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────
POSTGRES_USER=mimir
POSTGRES_PASSWORD=mimir
POSTGRES_DB=mimir
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── MongoDB ──────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=mimir
MONGO_INITDB_ROOT_PASSWORD=mimir
MONGO_DB=mimir
MONGO_HOST=mongo
MONGO_PORT=27017

# ── OpenSearch ───────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# ── Kafka ────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_NOTE_CHANGED=mimir.note.changed

# ── LLM 프로바이더 ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...

# ── vault ────────────────────────────────────────
# 호스트 머신에서 vault git 저장소가 위치한 절대 경로
# compose.yml에서 mimir-ingest와 mimir-link 컨테이너에 마운트됨
VAULT_PATH=/path/to/your/vault

# ── webhook ──────────────────────────────────────
# GitHub webhook secret (선택, 설정 시 서명 검증 활성화)
WEBHOOK_SECRET=

# ── Airflow ──────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://mimir:mimir@postgres:5432/airflow

# ── 임베딩 모델 ──────────────────────────────────
# sentence-transformers 모델명 (로컬 다운로드)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
